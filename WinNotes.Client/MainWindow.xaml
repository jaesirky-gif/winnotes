<Window x:Class="WinNotes.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WinNotes.Client.Converters"
        Title="WinNotes"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#E9DCC8">
  <Window.Resources>
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <SolidColorBrush x:Key="PageTextBrush" Color="#2F261B" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#7B664C" />
    <SolidColorBrush x:Key="PanelBrush" Color="#F8F2E9" />
    <SolidColorBrush x:Key="PanelStrongBrush" Color="#FFFDF9" />
    <SolidColorBrush x:Key="AccentBrush" Color="#BC7A34" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#935419" />
    <SolidColorBrush x:Key="DangerBrush" Color="#B24837" />

    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,18,0,8" />
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{StaticResource PageTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="RootBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="RootBorder" Property="Background" Value="#FFF8EF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PillButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource PageTextBrush}" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#E2D3BF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="999">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Background" Value="#FFF9F1" />
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <ContentPresenter />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="18">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="286" />
      <ColumnDefinition Width="360" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Margin="0,0,14,0"
            Background="{StaticResource PanelBrush}"
            CornerRadius="28"
            Padding="18"
            BorderBrush="#FDF9F1"
            BorderThickness="1">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Ellipse Width="12" Height="12" Fill="#FF5F57" />
            <Ellipse Width="12" Height="12" Margin="8,0,0,0" Fill="#FEBC2E" />
            <Ellipse Width="12" Height="12" Margin="8,0,0,0" Fill="#28C840" />
          </StackPanel>

          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="macOS Notes 风格"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="12"
                         FontWeight="SemiBold" />
              <TextBlock Text="WinNotes C#"
                         Margin="0,4,0,0"
                         FontSize="28"
                         FontWeight="Bold"
                         Foreground="{StaticResource PageTextBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    VerticalAlignment="Top"
                    Style="{StaticResource PillButtonStyle}"
                    Click="NewFolderButton_Click"
                    Content="新建文件夹" />
          </Grid>

          <TextBlock Style="{StaticResource SectionLabelStyle}" Text="智能文件夹" />
          <ItemsControl ItemsSource="{Binding SmartSidebarItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Tag="{Binding Id}"
                        Click="SidebarButton_Click">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                          <Setter Property="Background" Value="#FFFBF6" />
                          <Setter Property="BorderBrush" Value="#E2C49F" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Hint}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="8,3"
                            Background="#F5E5D2"
                            CornerRadius="999"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Count}" Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" />
                    </Border>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Style="{StaticResource SectionLabelStyle}" Text="我的文件夹" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding FolderSidebarItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Button Grid.Column="0"
                          Tag="{Binding Id}"
                          Click="SidebarButton_Click"
                          Margin="0">
                    <Button.Style>
                      <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#FFFBF6" />
                            <Setter Property="BorderBrush" Value="#E2C49F" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Hint}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0" />
                      </StackPanel>
                      <Border Grid.Column="1"
                              Padding="8,3"
                              Background="#F5E5D2"
                              CornerRadius="999"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding Count}" Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" />
                      </Border>
                    </Grid>
                  </Button>

                  <Button Grid.Column="1"
                          Margin="8,0,0,0"
                          VerticalAlignment="Center"
                          Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Tag="{Binding Id}"
                          Click="DeleteFolderButton_Click"
                          Background="#FFF0ED"
                          BorderBrush="#F0D2CB"
                          BorderThickness="1"
                          Foreground="{StaticResource DangerBrush}"
                          FontWeight="Bold"
                          Width="34"
                          Height="34"
                          Content="×" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button DockPanel.Dock="Bottom"
                Margin="0,16,0,0"
                Height="42"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="NewNoteButton_Click"
                Content="新建备忘录" />
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Margin="0,0,14,0"
            Background="{StaticResource PanelBrush}"
            CornerRadius="28"
            Padding="18"
            BorderBrush="#FDF9F1"
            BorderThickness="1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="搜索"
                     Foreground="{StaticResource MutedTextBrush}"
                     FontSize="12"
                     FontWeight="SemiBold" />
          <TextBox x:Name="SearchBox"
                   Margin="0,8,0,0"
                   MinHeight="44"
                   Padding="14,8"
                   FontSize="15"
                   Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

          <Grid Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{Binding ListTitle}"
                         FontSize="24"
                         FontWeight="Bold"
                         Foreground="{StaticResource PageTextBrush}" />
              <TextBlock Text="{Binding ListSubtitle}"
                         Margin="0,6,0,0"
                         Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="12,10"
                    Background="#FFFBF6"
                    CornerRadius="16"
                    VerticalAlignment="Top">
              <TextBlock Text="{Binding VisibleNoteCount}"
                         FontWeight="Bold"
                         Foreground="{StaticResource PageTextBrush}" />
            </Border>
          </Grid>
        </StackPanel>

        <ListBox x:Name="NotesListBox"
                 ItemsSource="{Binding VisibleNotes}"
                 SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,10"
                      Padding="16"
                      CornerRadius="20"
                      BorderThickness="1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFF9F1" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                        <Setter Property="Background" Value="{StaticResource PanelStrongBrush}" />
                        <Setter Property="BorderBrush" Value="#E0B87C" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>

                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PageTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="已置顶"
                               Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                  </Grid>

                  <TextBlock Text="{Binding Preview}"
                             Margin="0,10,0,14"
                             Foreground="{StaticResource MutedTextBrush}"
                             TextWrapping="Wrap"
                             MaxHeight="42" />

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding UpdatedShortText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" />
                    <Border Grid.Column="1"
                            Padding="8,3"
                            Background="#F5E5D2"
                            CornerRadius="999">
                      <TextBlock Text="{Binding FolderName}"
                                 Foreground="{StaticResource AccentDarkBrush}"
                                 FontSize="12"
                                 FontWeight="SemiBold" />
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="2"
            Background="{StaticResource PanelStrongBrush}"
            CornerRadius="28"
            Padding="20"
            BorderBrush="#FDF9F1"
            BorderThickness="1">
      <Grid>
        <Border Visibility="{Binding SelectedNote, Converter={StaticResource InverseNullToVisibilityConverter}}"
                Background="#FFF9F1"
                CornerRadius="24"
                Padding="36">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="没有可显示的内容"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="创建第一条备忘录"
                       Margin="0,10,0,0"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{StaticResource PageTextBrush}" />
            <TextBlock Text="你可以先建立一个文件夹，再开始记录文本、清单和灵感。"
                       Margin="0,14,0,0"
                       FontSize="16"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
              <Button Style="{StaticResource PrimaryButtonStyle}"
                      Click="NewNoteButton_Click"
                      Content="新建备忘录" />
              <Button Margin="10,0,0,0"
                      Style="{StaticResource PillButtonStyle}"
                      Click="NewFolderButton_Click"
                      Content="新建文件夹" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Visibility="{Binding SelectedNote, Converter={StaticResource NullToVisibilityConverter}}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TitleTextBox"
                     Margin="0,0,16,0"
                     FontSize="38"
                     FontWeight="Bold"
                     Foreground="{StaticResource PageTextBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Button x:Name="PinButton"
                      Margin="0,0,8,0"
                      Style="{StaticResource ToolbarButtonStyle}"
                      Click="PinButton_Click"
                      Content="置顶" />
              <Button Style="{StaticResource ToolbarButtonStyle}"
                      Background="#FFF0ED"
                      BorderBrush="#F0D2CB"
                      Foreground="{StaticResource DangerBrush}"
                      Click="DeleteNoteButton_Click"
                      Content="删除" />
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}">
              <Run Text="{Binding SelectedNote.FolderName, Mode=OneWay}" />
              <Run Text=" · 最近编辑 " />
              <Run Text="{Binding SelectedNote.UpdatedLongText, Mode=OneWay}" />
            </TextBlock>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         Foreground="{StaticResource MutedTextBrush}"
                         Text="所在文件夹" />
              <ComboBox Width="180"
                        Padding="8,4"
                        ItemsSource="{Binding Folders}"
                        DisplayMemberPath="Name"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding SelectedNote.FolderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </Grid>

          <WrapPanel Grid.Row="2" Margin="0,18,0,12">
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="BoldButton_Click" Content="粗体" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="ItalicButton_Click" Content="斜体" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="UnderlineButton_Click" Content="下划线" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="HeadingButton_Click" Content="标题" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="BulletsButton_Click" Content="项目符号" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="NumberingButton_Click" Content="编号" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="QuoteButton_Click" Content="引用" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="ClearFormatButton_Click" Content="清除格式" />
          </WrapPanel>

          <Border Grid.Row="3"
                  Margin="0,0,0,0"
                  Background="#FFF8EF"
                  BorderBrush="#F0E0CC"
                  BorderThickness="1"
                  CornerRadius="24">
            <RichTextBox x:Name="EditorBox"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsTab="True"
                         TextChanged="EditorBox_TextChanged" />
          </Border>

          <TextBlock Grid.Row="4"
                     Margin="4,14,0,0"
                     Foreground="{StaticResource MutedTextBrush}"
                     FontSize="12"
                     Text="{Binding SaveStatusMessage}" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
